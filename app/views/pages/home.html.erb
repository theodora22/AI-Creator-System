<div class="fixed inset-0 bg-[#FFFDF6] flex flex-col justify-between p-12 box-border overflow-hidden font-sans">

  <div class="flex justify-between items-start w-full">

    <div class="flex items-center select-none -mt-6 -ml-6">
      <%= image_tag "logo.png", alt: "ContentFlow Logo", class: "h-9 w-auto object-contain" %>
    </div>

    <div class="flex flex-col items-end space-y-1 -mt-6 -mr-6">
      <% if user_signed_in? %>
        <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs font-semibold text-gray-400 hover:text-gray-700 underline decoration-gray-300 hover:decoration-gray-700 underline-offset-4 transition duration-150 ease-in-out cursor-pointer" %>
        <span class="text-[9px] text-gray-400 font-bold uppercase tracking-wider">
          <%= current_user.email %>
        </span>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "text-xs font-semibold text-gray-400 hover:text-gray-700 underline decoration-gray-300 hover:decoration-gray-700 underline-offset-4 transition duration-150 ease-in-out" %>
      <% end %>
    </div>
  </div>

  <div class="flex-1 flex flex-col md:flex-row justify-between items-stretch w-full pb-6">

    <div class="text-left font-black text-[#FF5733] leading-[0.76] tracking-tighter select-none flex flex-col justify-start pt-16 md:pt-24 -ml-6 md:-ml-12" style="font-size: clamp(6.5rem, 14vw, 16.5rem);">
      <span class="block">START</span>
      <span class="block">CREATING</span>
      <span class="block">GREAT</span>
      <span class="block">CONTENT</span>
    </div>

    <div class="flex flex-col items-center md:items-end justify-end mr-4 md:mr-12 mb-2">
      <% if user_signed_in? %>
        <div class="flex flex-col items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-56 w-56 text-black stroke-current mb-2" fill="none" viewBox="0 0 24 24"
    stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="4" x2="12" y2="20" />
            <polyline points="5 13 12 20 19 13" />
          </svg>

          <%= link_to "View Content Reports", content_reports_path, class: "text-xl md:text-2xl font-bold text-black hover:text-[#FF5733] underline decoration-black hover:decoration-[#FF5733] underline-offset-8 transition duration-200 cursor-pointer text-center" %>
        </div>
      <% else %>
        <div class="flex flex-col items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-56 w-56 text-black stroke-current mb-2 animate-bounce" fill="none" viewBox="0 0 24 24"
    stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="4" x2="12" y2="20" />
            <polyline points="5 13 12 20 19 13" />
          </svg>

          <div class="flex flex-col items-center space-y-3">
            <%= link_to "Log in", new_user_session_path, class: "text-xl md:text-2xl font-bold text-black hover:text-[#FF5733] underline decoration-black hover:decoration-[#FF5733] underline-offset-8 transition duration-200 cursor-pointer text-center" %>
            <%= link_to "Sign up", new_user_registration_path, class: "text-xl md:text-2xl font-bold text-gray-400 hover:text-[#FF5733] underline decoration-gray-300 hover:decoration-[#FF5733] underline-offset-8 transition duration-200 cursor-pointer text-center" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>


  <div class="h-2 invisible"></div>

</div>
