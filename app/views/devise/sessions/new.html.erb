<div class="fixed inset-0 bg-[#FFFDF6] flex flex-col items-center justify-center px-4 overflow-y-auto">

  <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-sm border border-gray-100 box-border">

    <div class="flex justify-center mb-6">
      <%= image_tag "logo.png", alt: "ContentFlow Logo", class: "h-6 w-auto" %>
    </div>

    <h2 class="text-2xl font-semibold text-gray-900 text-center mb-6">Log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4", autocomplete: "off" }) do |f| %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "username", class: "w-full px-3 py-2.5 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#E25C37] focus:border-[#E25C37] text-sm" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-3 py-2.5 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#E25C37] focus:border-[#E25C37] text-sm" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-[#E25C37] focus:ring-[#E25C37] border-gray-300 rounded" %>
          <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-600" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Log in", class: "w-full bg-[#E25C37] hover:bg-[#c84e2e] text-white font-medium py-3 px-4 rounded-xl transition duration-200 text-sm cursor-pointer shadow-sm text-center" %>
      </div>

    <% end %>

    <%= render "devise/shared/links" %>

  </div>
</div>
