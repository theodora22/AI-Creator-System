<div class="mt-6 text-center text-sm text-gray-500 space-y-2 flex flex-col items-center w-full border-t border-gray-100 pt-4">

  <%- if controller_name != 'sessions' %>
    <%= link_to "Already have an account? Log in", new_session_path(resource_name), class: "hover:underline text-gray-600 font-medium" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Don't have an account? Sign up", new_registration_path(resource_name), class: "hover:underline text-orange-500 font-medium" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "hover:underline text-gray-400 text-xs mt-1" %>
  <% end %>

</div>
