<div class="fixed inset-0 flex flex-col items-center justify-center bg-transparent px-4">
  <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-sm border border-gray-100">

    <div class="flex justify-center mb-6">
      <%= image_tag "logo.png", alt: "ContentFlow Logo", class: "h-10" %>
    </div>

    <h2 class="text-2xl font-semibold text-gray-900 text-center mb-6">Sign up</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-sm" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-gray-400 block mb-1">(<%= @minimum_password_length %> characters minimum)</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-sm" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-sm" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Sign up", class: "w-full bg-orange-500 hover:bg-orange-600 text-white font-medium py-2 px-4 rounded-lg transition duration-200 text-sm cursor-pointer" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>

  </div>
</div>
