<!-- app/views/reports/show.html.erb -->

<div class="report-page">
  <h1 class="font-bold text-4xl mb-4">
    <%= @report.title %>
  </h1>

  <div class="mb-6">
    <p class="text-gray-600">
      Created on
      <%= @report.created_at.strftime("%B %d, %Y at %I:%M %p") %>
    </p>
  </div>

  <div class="report-content mb-8">
    <h2 class="text-2xl font-semibold mb-2">Report Content</h2>

    <% if @report.content.present? %>
      <div class="prose">
        <%= simple_format(@report.content) %>
      </div>
    <% else %>
      <p>No content available for this report.</p>
    <% end %>
  </div>

  <div class="flex gap-4">
    <%= link_to "Back to Reports", reports_path, class: "btn btn-secondary" %>

    <%= link_to "Edit Report",
                edit_report_path(@report),
                class: "btn btn-primary" %>

    <%= link_to "Delete Report",
                report_path(@report),
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "Are you sure you want to delete this report?"
                },
                class: "btn btn-danger" %>
  </div>
</div>
