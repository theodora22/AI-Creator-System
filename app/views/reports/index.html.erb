<!-- app/views/reports/index.html.erb -->

<h1>Content Reports</h1>

<p>Here you will see all your saved content reports.</p>

<%= link_to "Create New Report", new_report_path, class: "btn btn-primary" %>

<% if @reports.any? %>
  <table class="table mt-4">
    <thead>
      <tr>
        <th>Title</th>
        <th>Created At</th>
        <th colspan="3">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @reports.each do |report| %>
        <tr>
          <td><%= report.title %></td>
          <td><%= report.created_at.strftime("%B %d, %Y") %></td>

          <td><%= link_to "View", report_path(report) %></td>
          <td><%= link_to "Edit", edit_report_path(report) %></td>
          <td>
            <%= link_to "Delete",
                        report_path(report),
                        data: {
                          turbo_method: :delete,
                          turbo_confirm: "Are you sure?"
                        } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="mt-4">No content reports found.</p>
<% end %>
