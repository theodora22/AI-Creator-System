<div id="page-container" class="fixed inset-0 bg-[#FFFDF6] flex flex-col justify-between pt-12 pb-12 pr-12 pl-6 md:pl-0 box-border overflow-y-auto font-sans">

  <div class="w-full flex-1 flex flex-col justify-between">

    <div>
      <!-- Header -->
      <div class="flex justify-between items-start w-full mb-8 select-none">
        <div class="flex items-center select-none -mt-6 md:ml-6">
          <%= link_to root_path do %>
            <%= image_tag "logo.png", alt: "ContentFlow Logo", class: "h-9 w-auto object-contain hover:opacity-80 transition-opacity" %>
          <% end %>
        </div>

        <div class="flex flex-col items-end space-y-1 -mt-6 -mr-6 select-none">
          <% if user_signed_in? %>
            <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs font-semibold text-gray-400 hover:text-gray-700 transition duration-150 ease-in-out cursor-pointer" %>
            <span class="text-[9px] text-gray-400 font-semibold uppercase tracking-wider">
              <%= current_user.email %>
            </span>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "text-xs font-semibold text-gray-400 hover:text-gray-700 transition duration-150 ease-in-out" %>
          <% end %>
        </div>
      </div>

      <!-- Title & Giant Button Row (Aligned on the exact same baseline and right-aligned with the table grid) -->
      <div class="flex flex-col md:flex-row md:items-end justify-between w-full select-none ml-6 max-w-7xl lg:max-w-[90vw] transition-morph" style="margin-bottom: var(--header-margin-bottom);">
        <div class="w-full md:w-auto">
          <h1 class="font-medium text-[#FF5733] leading-[0.76] tracking-tighter uppercase transition-morph" style="font-size: var(--title-font-size);">
            HERE ARE<br>YOUR REPORTS
          </h1>
        </div>

        <div class="mt-4 md:mt-0 md:mb-0 ml-6 md:ml-0 flex items-end gap-x-2 group">
          <!-- Giant Plus Link -->
          <%= link_to new_content_report_path, class: "group inline-flex items-end cursor-pointer select-none transition-morph", style: "margin-right: var(--plus-margin-right);" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="select-none transition-morph" style="width: var(--plus-size); height: var(--plus-size); transform: translateY(var(--plus-translate-y));" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <defs>
                <clipPath id="plus-clip">
                  <rect x="0" y="0" width="24" height="24" class="arrow-mask-rect" />
                </clipPath>
              </defs>
              <!-- Base Plus (Black) -->
              <g stroke="black" stroke-width="3" fill="none">
                <path d="M12 4.5v15m7.5-7.5h-15" />
              </g>
              <!-- Filled Plus (Orange) -->
              <g stroke="#FF5733" stroke-width="3" fill="none" clip-path="url(#plus-clip)">
                <path d="M12 4.5v15m7.5-7.5h-15" />
              </g>
            </svg>
          <% end %>

          <!-- Text Link -->
          <%= link_to new_content_report_path, class: "inline-flex items-end text-xl md:text-2xl font-semibold text-black hover:text-[#FF5733] cursor-pointer whitespace-nowrap lowercase pb-2 transition-morph compact-text-link", style: "position: relative; top: var(--text-link-top);" do %>
            <span>new report</span>
          <% end %>
        </div>
      </div>

      <!-- Reports Table (Perfectly matching the title row width boundaries) -->
      <div id="reports-table-container" class="w-full overflow-x-auto pb-6 scrollbar-thin mt-[50px] max-w-7xl lg:max-w-[90vw] ml-6" style="margin-top: 50px;">
        <table class="w-full min-w-[700px] md:min-w-full table-auto border-collapse">
          <thead>
            <tr class="text-lg md:text-2xl font-semibold text-black lowercase select-none">
              <th class="pb-2 text-left font-semibold w-2/5">title</th>
              <th class="pb-2 text-left font-semibold w-1/4">platform</th>
              <th class="pb-2 text-left font-semibold w-1/5">created</th>
              <th class="pb-2 text-right font-semibold w-1/10"></th>
            </tr>
            <!-- Premium Rounded Capsule Divider Line -->
            <tr>
              <td colspan="4" class="pb-3 pt-1">
                <div class="h-[6px] bg-[#FF5733] w-full rounded-full"></div>
              </td>
            </tr>
          </thead>
          <tbody>
            <% if @content_reports.any? %>
              <% @content_reports.each_with_index do |content_report, index| %>
                <% is_hidden = index >= 5 %>
                <tr class="border-b border-gray-200 hover:bg-black/[0.01] transition-colors duration-150<%= " hidden-report-row reveal-row" if is_hidden %>">
                  <td class="py-5 text-lg md:text-xl lg:text-2xl font-semibold text-black tracking-tight pr-4">
                    <%= link_to content_report.content_title.presence || "Untitled Report", content_report_path(content_report), class: "hover:text-[#FF5733] transition-colors break-words" %>
                  </td>
                  <td class="py-5 pr-4 text-base md:text-lg lg:text-xl font-semibold text-[#FF5733] whitespace-nowrap">
                    <%= content_report.content_platform.presence || "Draft" %>
                  </td>
                  <td class="py-5 text-base md:text-lg lg:text-xl font-semibold text-black tracking-tight whitespace-nowrap">
                    <%= content_report.created_at.strftime("%B %d, %Y") %>
                  </td>
                  <td class="py-5 text-right text-base md:text-lg lg:text-xl font-semibold tracking-tight select-none text-black whitespace-nowrap">
                    <%= link_to "view", content_report_path(content_report), class: "hover:text-[#FF5733] transition-colors" %>
                    <span class="text-gray-300 mx-1">/</span>
                    <%= link_to "edit", edit_content_report_path(content_report), class: "hover:text-[#FF5733] transition-colors" %>
                    <span class="text-gray-300 mx-1">/</span>
                    <%= link_to "delete", content_report_path(content_report), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-[#FF5733]" %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center py-20 border-2 border-dashed border-gray-200 rounded-2xl bg-white/50">
                  <p class="text-gray-400 font-medium mb-4">No reports created yet.</p>
                  <%= link_to new_content_report_path, class: "inline-flex items-center text-sm font-semibold text-[#FF5733]" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="4.5" stroke="currentColor" class="w-4 h-4 text-[#FF5733] mr-1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Create your first report
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Footer see more -->
    <% if @content_reports.size > 5 %>
      <button id="see-more-trigger" class="w-full flex flex-col items-center justify-center pt-8 pb-4 select-none cursor-pointer hover:opacity-70 transition-opacity focus:outline-none border-none bg-transparent">
        <span class="text-base md:text-lg font-semibold text-black mb-2 tracking-tight">see more</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="4" stroke="currentColor" class="w-6 h-6 md:w-8 md:h-8 text-black">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
        </svg>
      </button>
    <% end %>

  </div>
</div>

<style>
  /* -------------------------------------------------------------------------
     Morphing Header Transition Variables & GPU Acceleration
     Allows seamless, butter-smooth layout morphs when clicking "see more".
     ------------------------------------------------------------------------- */
  #page-container {
    --title-font-size: clamp(4.5rem, 11vw, 11.5rem);
    --header-margin-bottom: clamp(5rem, 8vw, 8rem);
    --plus-size: 128px;
    --plus-margin-right: -25px;
    --plus-translate-y: calc(18.75% - 10px);
    --text-link-top: 10px;
  }

  @media (min-width: 768px) {
    #page-container {
      --plus-size: 160px;
      --plus-margin-right: -53px;
      --plus-translate-y: calc(18.75% - 10px);
    }
  }

  /* Compact state triggered on click */
  #page-container.compact-header {
    --title-font-size: clamp(2.5rem, 5.5vw, 4.5rem) !important;
    --header-margin-bottom: 2rem !important;
    --plus-size: 48px !important;
    --plus-margin-right: -5px !important;
    --plus-translate-y: calc(18.75% - 3px) !important;
    --text-link-top: 0px !important;
  }

  @media (min-width: 768px) {
    #page-container.compact-header {
      --plus-size: 64px !important;
      --plus-margin-right: -6px !important;
      --plus-translate-y: calc(18.75% - 4px) !important;
    }
  }

  /* Compact text sizing scaling */
  #page-container.compact-header .compact-text-link {
    font-size: 1.125rem !important; /* text-lg */
    padding-bottom: 2px !important;
  }


  /* GPU Layer and Property-Specific Transitions (Avoids transition: all stutters) */
  .transition-morph {
    will-change: font-size, margin-bottom, margin-right, top, width, height, transform, padding;
    transition: font-size 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                margin-bottom 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                margin-right 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                top 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                width 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                height 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                padding-bottom 1.0s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.2s ease,
                background-color 0.2s ease;
  }

  /* Hide rows 6-20 by default */
  .hidden-report-row {
    display: none;
  }

  /* Reveal when compact-header is active */
  #page-container.compact-header .hidden-report-row {
    display: table-row !important;
  }

  /* Scroll Reveal Base State with Premium Apple-like Blur */
  .reveal-row {
    opacity: 0 !important;
    filter: blur(8px) !important;
    transform: translateY(30px) !important;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) !important;
    will-change: opacity, filter, transform;
  }

  /* Visible State once intersected */
  .reveal-row.is-visible {
    opacity: 1 !important;
    filter: blur(0) !important;
    transform: translateY(0) !important;
  }

  /* Base styling for see-more trigger transitions */
  #see-more-trigger {
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                height 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                padding 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                margin 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Fade and collapse see-more button */
  #page-container.compact-header #see-more-trigger {
    opacity: 0 !important;
    pointer-events: none !important;
    height: 0px !important;
    padding-top: 0px !important;
    padding-bottom: 0px !important;
    margin-top: 0px !important;
    margin-bottom: 0px !important;
    visibility: hidden;
    overflow: hidden;
  }
</style>

<script>
  (function() {
    let observer;

    const initScrollReveal = (pageContainer) => {
      // Disconnect existing observer if any to prevent memory leaks
      if (observer) {
        observer.disconnect();
      }

      const revealRows = document.querySelectorAll(".reveal-row");
      if (!revealRows.length) return;

      const observerOptions = {
        root: pageContainer,
        rootMargin: "0px 0px -50px 0px", // Trigger slightly inside the viewport bottom
        threshold: 0.02
      };

      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      revealRows.forEach(row => {
        row.classList.remove("is-visible");
        observer.observe(row);
      });
    };

    const initSeeMore = () => {
      const seeMoreBtn = document.getElementById("see-more-trigger");
      const pageContainer = document.getElementById("page-container");
      const reportsTable = document.getElementById("reports-table-container");

      if (pageContainer) {
        initScrollReveal(pageContainer);
      }

      if (seeMoreBtn && pageContainer && reportsTable) {
        seeMoreBtn.addEventListener("click", (e) => {
          e.preventDefault();

          // 1. Toggle compact morphing state via CSS variables
          pageContainer.classList.add("compact-header");

          // 2. Coordinated smooth scroll once header morph executes its initial acceleration
          setTimeout(() => {
            pageContainer.scrollTo({ top: 0, behavior: "smooth" });
          }, 180);
        });
      }
    };

    // Initialize on turbo loads and direct loads
    document.addEventListener("turbo:load", initSeeMore);
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initSeeMore);
    } else {
      initSeeMore();
    }
  })();
</script>
