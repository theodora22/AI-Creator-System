<div class="max-w-4xl mx-auto px-4 py-6">
  <h1 class="font-bold text-4xl mb-6">
    Edit Content Report
  </h1>

  <%= form_with model: @content_report, local: true do |form| %>

    <% if @content_report.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
        <h2 class="font-semibold mb-2">
          <%= pluralize(@content_report.errors.count, "error") %>
          prevented this report from being saved:
        </h2>

        <ul class="list-disc ml-6">
          <% @content_report.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :content_title, class: "block font-semibold mb-2" %>
      <%= form.text_field :content_title,
          class: "w-full border rounded-lg p-3" %>
    </div>

    <div class="mb-4">
      <%= form.label :content_hook, class: "block font-semibold mb-2" %>
      <%= form.text_field :content_hook,
          class: "w-full border rounded-lg p-3" %>
    </div>

    <div class="mb-4">
      <%= form.label :content_platform, class: "block font-semibold mb-2" %>
      <%= form.text_field :content_platform,
          class: "w-full border rounded-lg p-3" %>
    </div>

    <div class="mb-4">
      <%= form.label :content_length, class: "block font-semibold mb-2" %>
      <%= form.text_field :content_length,
          class: "w-full border rounded-lg p-3" %>
    </div>

    <div class="mb-4">
      <%= form.label :content_type, class: "block font-semibold mb-2" %>
      <%= form.text_area :content_type,
          rows: 4,
          class: "w-full border rounded-lg p-3" %>
    </div>

  <% end %>
</div>
