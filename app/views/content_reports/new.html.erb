<div class="min-h-screen bg-[#FFFDF3]">
  <div class="w-full max-w-2xl mx-auto px-6 py-12">

    <div class="mb-8">
      <%= link_to "← Back", content_reports_path, class: "text-sm text-[#9A9488] hover:text-[#E25C37] transition-colors" %>
    </div>

    <h1 style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 500;" class="text-3xl uppercase tracking-tight text-[#E25C37] mb-8">
      New Report
    </h1>

    <%= form_with model: @content_report, class: "space-y-6" do |f| %>

      <% input_class = "w-full border border-[#E4D8BE] bg-[#FFFDF3] rounded-xl px-4 py-3 text-sm text-[#171717] placeholder:text-[#8F887C] focus:outline-none focus:ring-2 focus:ring-[#E25C37]/20 focus:border-[#E25C37]" %>
      <% label_class = "block text-xs text-[#9A9488] font-semibold uppercase tracking-wider mb-1.5" %>

      <div>
        <label class="<%= label_class %>">Title</label>
        <%= f.text_field :content_title, class: input_class, placeholder: "e.g. Instagram Reel Script" %>
      </div>

      <div>
        <label class="<%= label_class %>">Platform</label>
        <%= f.text_field :content_platform, class: input_class, placeholder: "e.g. Instagram, YouTube, LinkedIn" %>
      </div>

      <div>
        <label class="<%= label_class %>">Type</label>
        <%= f.text_field :content_type, class: input_class, placeholder: "e.g. Reel, Thread, Blog Post" %>
      </div>

      <div>
        <label class="<%= label_class %>">Hook</label>
        <%= f.text_area :content_hook, rows: 2, class: input_class, placeholder: "Your opening line or hook" %>
      </div>

      <div>
        <label class="<%= label_class %>">Length</label>
        <%= f.text_field :content_length, class: input_class, placeholder: "e.g. 30–60 seconds, 800–1200 words" %>
      </div>

      <div>
        <label class="<%= label_class %>">System Prompt</label>
        <%= f.text_area :system_prompt, rows: 5, class: input_class, placeholder: "Instructions for the AI..." %>
      </div>

      <%= f.submit "Create Report",
        class: "bg-[#E25C37] hover:bg-[#c84e2e] text-white text-sm font-semibold px-6 py-3 rounded-xl transition-colors duration-200 cursor-pointer" %>

    <% end %>

  </div>
</div>
