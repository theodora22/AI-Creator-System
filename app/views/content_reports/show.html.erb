<div class="fixed inset-0 -z-10 pointer-events-none" style="background: #FFFDF3;"></div>

 <div class="w-full py-10 max-w-2xl mx-auto">

    <div class="flex items-center justify-between mb-8">
      <%= link_to "← Back", content_reports_path, class: "text-sm text-gray-400 hover:text-[#E25C37] transition-colors" %>
      <div class="flex items-center gap-3">
        <%= link_to "Edit", edit_content_report_path(@content_report), class: "text-sm text-gray-600 hover:text-[#E25C37] transition-colors" %>
        <%= link_to "Delete", content_report_path(@content_report), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-sm text-red-500 hover:underline" %>
      </div>
    </div>

    <h1 class="text-5xl md:text-7xl font-black uppercase leading-[0.9] tracking-tight text-[#E25C37] mb-8">
          <%= @content_report.content_title %>
        </h1>

    <div class="flex items-center gap-3 mb-8 text-sm text-gray-400">
      <span class="px-2 py-1 rounded-full bg-orange-50 text-[#E25C37] text-xs font-medium">
        <%= @content_report.content_platform || "Draft" %>
      </span>
      <span><%= @content_report.created_at.strftime("%B %d, %Y") %></span>
    </div>

    <% if @content_report.content_hook.present? %>
      <div class="mb-6 border-l-2 border-[#E25C37] pl-4">
        <p class="text-xs text-[#E25C37] font-medium uppercase tracking-wider mb-1">Hook</p>
        <p class="text-sm text-[#1C1C1C] leading-relaxed"><%= @content_report.content_hook %></p>
      </div>
    <% end %>

    <% if @content_report.content_type.present? %>
      <div class="mb-6">
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">Type</p>
        <p class="text-sm text-[#1C1C1C]"><%= @content_report.content_type %></p>
      </div>
    <% end %>

    <% if @content_report.content_length.present? %>
      <div class="mb-6">
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">Length</p>
        <p class="text-sm text-[#1C1C1C]"><%= @content_report.content_length %></p>
      </div>
    <% end %>

    <% if @content_report.system_prompt.present? %>
      <div class="mb-8">
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">System Prompt</p>
        <p class="text-sm text-[#1C1C1C] leading-relaxed whitespace-pre-wrap"><%= @content_report.system_prompt %></p>
      </div>
    <% end %>

    <hr class="border-gray-100 mb-6">

    <%= button_to "Start new chat", content_report_chats_path(@content_report), class: "bg-[#E25C37] hover:bg-[#c84e2e] text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors duration-200" %>

  </div>
