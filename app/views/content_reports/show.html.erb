<%= button_to "New chat", content_report_chats_path(@content_report), class: "bg-blue-600 text-black px-6 py-3 rounded-md font-bold transition-colors hover:bg-blue-700" %>

<hr>

<div class="report-show-page">
  <div class="page-header">
    <h1><%= @content_report.content_title %></h1>

    <div class="actions">
      <%= link_to "Edit Report",
                  edit_content_report_path(@content_report),
                  class: "btn btn-secondary" %>

      <%= link_to "Back to Reports",
                  content_reports_path,
                  class: "btn btn-light" %>

      <%= link_to "Delete",
                  content_report_path(@content_report),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure you want to delete this report?"
                  },
                  class: "btn btn-danger" %>
    </div>
  </div>

  <div class="report-details">
    <div class="report-meta">
      <p>
        <strong>Status:</strong>
        <%= @content_report.content_platform || "Draft" %>
      </p>

      <p>
        <strong>Created:</strong>
        <%= @content_report.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>

      <p>
        <strong>Last Updated:</strong>
        <%= @content_report.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>
    </div>

    <hr>
  </div>
</div>
