<div class="w-full py-10 max-w-2xl mx-auto">

<hr>

<%= button_to "New chat", content_report_chats_path(@content_report), class: "btn btn-primary" %>

<hr>

<div class="report-show-page">
  <div class="page-header">
    <h1><%= @content_report.content_title %></h1>

    <div class="actions">
      <%= link_to "Edit Report",
                  edit_content_report_path(@content_report),
                  class: "btn btn-secondary" %>

      <%= link_to "Back to Reports",
                  content_reports_path,
                  class: "btn btn-light" %>

      <%= link_to "Delete",
                  content_report_path(@content_report),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure you want to delete this report?"
                  },
                  class: "btn btn-danger" %>
    </div>
  </div>

  <div class="report-details">
    <div class="report-meta">
      <p>
        <strong>Status:</strong>
        <%= @content_report.content_platform || "Draft" %>
      </p>

      <p>
        <strong>Created:</strong>
        <%= @content_report.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>

  <% if @content_report.content_hook.present? %>
    <div class="mb-6 border-l-2 border-[#E25C37] pl-4">
      <p class="text-xs text-[#E25C37] font-medium uppercase tracking-wider mb-1">Hook</p>
      <p class="text-sm text-[#1C1C1C] leading-relaxed"><%= @content_report.content_hook %></p>
    </div>
  <% end %>

    <hr>
  </div>
</div>

<!-- Clean, simple list of chats created under this specific report -->
<div class="report-chats-list mt-8">
  <h2 class="text-xl font-bold mb-4">Chats for this Report</h2>
  
  <% if @chats.any? %>
    <ul class="divide-y divide-gray-200">
      <% @chats.each do |chat| %>
        <li class="py-4 flex justify-between items-center">
          <div class="flex-grow">
            <%= link_to chat_path(chat), class: "block hover:underline" do %>
              <strong class="text-[#E25C37] text-lg"><%= chat.title.presence || "Untitled Chat" %></strong>
              <span class="text-gray-400 text-xs block mt-1">
                Last updated: <%= chat.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
              </span>
            <% end %>
          </div>
          <div>
            <%= button_to "Delete Chat", chat_path(chat),
                          method: :delete,
                          form: { data: { turbo_confirm: "Are you sure you want to delete this chat?" } },
                          class: "btn btn-sm btn-danger cursor-pointer" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-400 text-sm">No chats created yet for this report. Click "New chat" above to get started!</p>
  <% end %>
</div>

</div>
