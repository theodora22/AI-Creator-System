<div class="w-full py-10 max-w-2xl mx-auto">

  <div class="mb-8">
    <%= link_to content_reports_path,
          class: "text-xs text-gray-400 hover:text-[#E25C37] transition-colors flex items-center gap-1" do %>
      ← All Reports
    <% end %>
  </div>

  <div class="flex justify-between items-start gap-4 mb-8">
    <h1 class="text-2xl font-semibold text-[#1C1C1C] leading-snug">
      <%= @content_report.content_title.presence || "Untitled" %>
    </h1>
    <div class="flex gap-2 shrink-0">
      <%= link_to "Edit", edit_content_report_path(@content_report),
            class: "text-sm text-[#E25C37] border border-[#E25C37] px-4 py-1.5 rounded-lg hover:bg-[#FFF3EE] transition-colors" %>
      <%= link_to "Delete", content_report_path(@content_report),
            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
            class: "text-sm text-gray-400 hover:text-red-500 transition-colors px-2 py-1.5" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-8">
    <% if @content_report.content_type.present? %>
      <div class="bg-[#FFF3EE] rounded-xl p-4">
        <p class="text-xs text-[#E25C37] font-medium uppercase tracking-wider mb-1">Content Type</p>
        <p class="text-sm text-[#1C1C1C] font-medium"><%= @content_report.content_type %></p>
      </div>
    <% end %>
    <% if @content_report.content_platform.present? %>
      <div class="bg-[#F5EDD8] rounded-xl p-4">
        <p class="text-xs text-[#8B6914] font-medium uppercase tracking-wider mb-1">Platform</p>
        <p class="text-sm text-[#1C1C1C] font-medium"><%= @content_report.content_platform %></p>
      </div>
    <% end %>
    <% if @content_report.content_length.present? %>
      <div class="bg-white border border-[#E8DFD0] rounded-xl p-4">
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">Length</p>
        <p class="text-sm text-[#1C1C1C] font-medium"><%= @content_report.content_length %></p>
      </div>
    <% end %>
    <div class="bg-white border border-[#E8DFD0] rounded-xl p-4">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-1">Created</p>
      <p class="text-sm text-[#1C1C1C] font-medium"><%= @content_report.created_at.strftime("%b %d, %Y") %></p>
    </div>
  </div>

  <% if @content_report.content_hook.present? %>
    <div class="mb-6 border-l-2 border-[#E25C37] pl-4">
      <p class="text-xs text-[#E25C37] font-medium uppercase tracking-wider mb-1">Hook</p>
      <p class="text-sm text-[#1C1C1C] leading-relaxed"><%= @content_report.content_hook %></p>
    </div>
  <% end %>

  <% if @content_report.system_prompt.present? %>
    <div class="bg-white border border-[#E8DFD0] rounded-2xl p-5 mb-8">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wider mb-3">System Prompt</p>
      <p class="text-sm text-[#1C1C1C] leading-relaxed whitespace-pre-wrap"><%= @content_report.system_prompt %></p>
    </div>
  <% end %>

  <%= button_to content_report_chats_path(@content_report), method: :post,
        class: "w-full bg-[#E25C37] hover:bg-[#c84e2e] text-white text-sm font-medium py-3 rounded-xl transition-colors duration-200 cursor-pointer" do %>
    Chat with this report →
  <% end %>

</div>
